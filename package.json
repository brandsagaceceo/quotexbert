{
  "name": "quotexbert",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "deploy": "git add -A && git diff --cached --quiet || git commit -m \"deploy: publish latest changes\" && git push origin main && powershell -Command \"Invoke-WebRequest -Method POST -Uri 'https://api.vercel.com/v1/integrations/deploy/prj_VmE4r9OklojtuAzXWl0f13um9ekj/9gCFlpypVu' -UseBasicParsing | Out-Null\" && echo \"Vercel build triggered successfully\"",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "echo 'Linting disabled'",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run typecheck && npm run lint && npm run build",
    "test:subscription-access": "tsx scripts/subscription-category-access.test.ts",
    "test:contractor-tiers": "tsx scripts/test-contractor-tiers.ts",
    "repair:subscription-categories": "tsx scripts/repair-stripe-category-entitlements.ts",
    "db:push": "prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "studio": "prisma studio",
    "dev:all": "concurrently \"npm run db:push\" \"npm run dev\" \"npm run studio\"",
    "seed:billing": "node seed-billing.js",
    "firebase:check": "node scripts/validate-firebase.js",
    "firebase:setup": "echo 'Please follow the guide in firebase-setup-guide.md' && npm run firebase:check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.864.0",
    "@capacitor/android": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/ios": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.0",
    "@clerk/nextjs": "^6.31.1",
    "@google-cloud/firestore": "^7.11.6",
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^6.14.0",
    "@stripe/react-stripe-js": "^3.10.0",
    "@stripe/stripe-js": "^7.9.0",
    "@vercel/blob": "^2.0.0",
    "clsx": "^2.1.1",
    "crypto": "^1.0.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.3.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.545.0",
    "nanoid": "^5.1.5",
    "next": "14.2.25",
    "openai": "^6.2.0",
    "posthog-js": "^1.260.1",
    "posthog-node": "^5.7.0",
    "prisma": "^6.14.0",
    "puppeteer": "^24.16.2",
    "qrcode.react": "^4.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "resend": "^6.0.1",
    "stripe": "^18.5.0",
    "svix": "^1.84.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "concurrently": "^9.2.0",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "eslint-plugin-unused-imports": "^4.1.4",
    "prettier": "^3.6.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
